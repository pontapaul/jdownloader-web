# JDownloader2 Deprecated API base URL.
# During development (npm run dev), point directly at your JD2 instance.
# In Docker production builds, set to /api so nginx proxies requests to the JD2 container.
VITE_JD_API_URL=http://localhost:3128

# User and group ID for the jdownloader-2 container process.
# Run `id -u` and `id -g` to find your values.
USER_ID=1000
GROUP_ID=1000

# Timezone for the jdownloader-2 container.
TZ=Europe/Rome
